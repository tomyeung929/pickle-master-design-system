{
  "rewrites": [
    { "source": "/", "destination": "/website/index-light.html" },
    { "source": "/dark", "destination": "/website/index.html" },
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/:path+", "destination": "/website/:path+" }
  ],
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs20.x",
      "maxDuration": 15
    }
  }
}
